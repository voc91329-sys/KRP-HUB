-- [8] PHẦN CUỐI: TOOL TP (BẬT/TẮT) & HOÀN TẤT
---------------------------------------------------------
local ToolTP_Enabled = false
local TOOL_NAME = "Dịch Chuyển" -- Định nghĩa tên Tool ở đây để không bị sai

-- Hàm cấp Tool
local function GiveTpTool()
    local backpack = Player:FindFirstChild("Backpack")
    if not backpack then return end
    
    -- Kiểm tra xem đã có tool chưa
    if backpack:FindFirstChild(TOOL_NAME) or Player.Character:FindFirstChild(TOOL_NAME) then return end

    local tool = Instance.new("Tool")
    tool.Name = TOOL_NAME
    tool.RequiresHandle = false
    tool.Parent = backpack

    tool.Activated:Connect(function()
        local mouse = Player:GetMouse()
        local targetPos = mouse.Hit.Position
        local hrp = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            hrp.CFrame = CFrame.new(targetPos + Vector3.new(0, 3, 0))
        end
    end)
end

-- Hàm xóa Tool
local function RemoveTpTool()
    local backpack = Player:FindFirstChild("Backpack")
    -- Xóa đúng tên TOOL_NAME
    if backpack and backpack:FindFirstChild(TOOL_NAME) then backpack[TOOL_NAME]:Destroy() end
    if Player.Character and Player.Character:FindFirstChild(TOOL_NAME) then Player.Character[TOOL_NAME]:Destroy() end
end

-- Toggle Bật/Tắt
Tab:CreateToggle({
    Name = "Công Cụ Dịch Chuyển",
    CurrentValue = false,
    Flag = "ToggleTpTool",
    Callback = function(Value)
        ToolTP_Enabled = Value
        if Value then
            GiveTpTool()
            Rayfield:Notify({Title = "KRP HUB", Content = "Đã bật Công Cụ Dịch Chuyển", Duration = 2})
        else
            RemoveTpTool()
            Rayfield:Notify({Title = "KRP HUB", Content = "Đã tắt và xóa Công Cụ Dịch Chuyển", Duration = 2})
        end
    end,
})

-- Tự động cấp lại khi hồi sinh (chỉ chạy nếu đang BẬT)
Player.CharacterAdded:Connect(function()
    if ToolTP_Enabled then
        task.wait(1)
        GiveTpTool()
    end
end)

